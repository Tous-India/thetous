# Meta Conversions API (server-side event tracking)
# Source: Meta Events Manager > Settings > Conversions API
META_PIXEL_ID=
META_ACCESS_TOKEN=

# Optional. When set, events route to the Test Events tab in Events Manager
# instead of the live dataset. Leave blank or unset in production.
META_TEST_EVENT_CODE=

# Meta Pixel (client-side, loaded in src/app/layout.js)
# NEXT_PUBLIC_ prefix exposes this to the browser bundle by Next.js convention.
# Same Pixel ID as META_PIXEL_ID above — duplicated because the server reads
# META_PIXEL_ID and the browser reads NEXT_PUBLIC_META_PIXEL_ID.
NEXT_PUBLIC_META_PIXEL_ID=

# Google Analytics 4 (client-side, loaded in src/app/layout.js)
NEXT_PUBLIC_GA_MEASUREMENT_ID=
